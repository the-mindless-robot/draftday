generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid()) @map("id")
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid()) @map("id")
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid()) @map("id")
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified") @db.Timestamptz(6)
  image         String?
  roles         String[]  @default([])
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime @db.Timestamptz(6)

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Fantasy ──────────────────────────────────────────────────────────────────

model Player {
  id         String  @id @default(cuid())
  fbgId      String  @unique @map("fbg_id")
  name       String
  team       String?
  age        Int?
  experience Int?
  byeWeek    Int?    @map("bye_week")

  // Tiers — stamped on import (no history)
  overallTier    String? @map("overall_tier")
  positionalTier String? @map("positional_tier")

  // Rankings — stamped on overall import (no history)
  pos            String?
  overallRank    Int?    @map("overall_rank")
  positionalRank Int?    @map("positional_rank")
  projPoints     Float?  @map("proj_points")
  projGames      Float?  @map("proj_games")
  upside         Float?
  downside       Float?

  // Salary cap — stamped on import (no history)
  scFbg250    String? @map("salary_cap_fbg_250")
  scFbg200    String? @map("salary_cap_fbg_200")
  scFbgScaled String? @map("salary_cap_fbg_scaled")
  scEspn200   String? @map("salary_cap_espn_200")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rankings PlayerRanking[]

  @@map("players")
}

// Audit log — one record per import session
model RankingImport {
  id         String   @id @default(cuid())
  source     String // "fbg" | "espn"
  position   String // "overall" | "QB" | "RB" | "WR" | "TE" | "FLEX" | "PK"
  season     Int
  rowCount   Int      @map("row_count")
  importedAt DateTime @default(now()) @map("imported_at")

  rankings PlayerRanking[]

  @@map("ranking_imports")
}

// One row per (player × import session) — never updated, only inserted
model PlayerRanking {
  id       String @id @default(cuid())
  playerId String @map("player_id")
  importId String @map("import_id")

  // Denormalized from RankingImport for join-free queries
  source     String
  position   String
  season     Int
  importedAt DateTime @map("imported_at")

  // Overall import fields
  overallRank Int?    @map("overall_rank")
  pos         String? // "QB" | "RB" | "WR" | "TE" etc.
  projPoints  Float?  @map("proj_points")
  projGames   Float?  @map("proj_games")
  downside    Float?
  upside      Float?

  // Positional import fields
  positionalRank Int? @map("positional_rank")

  player Player        @relation(fields: [playerId], references: [id])
  import RankingImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@unique([playerId, importId])
  @@map("player_rankings")
}
